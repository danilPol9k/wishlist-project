# Backend
JWT_SECRET=example-jwt-secret-change-me
PORT=3000
# Через запятую: локальный фронт и HTTPS-домен фронтенда после деплоя
CORS_ORIGIN=http://localhost:8081,https://example-domain.ru

# PostgreSQL
POSTGRES_USER=example_user
POSTGRES_PASSWORD=example_password
POSTGRES_DB=example_kupipodariday
POSTGRES_HOST=database
POSTGRES_PORT=5432
PGDATA=/var/lib/postgresql/data/pgdata

# Frontend build
# Для локальной проверки оставьте localhost. После регистрации домена замените на https://api.<ваш-домен>
FRONTEND_API_URL=http://localhost:4000
